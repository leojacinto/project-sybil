<?xml version="1.0" encoding="utf-8" ?>
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null">
<style>
.ta{font-family:'Source Sans Pro',-apple-system,sans-serif;max-width:1200px;margin:0 auto;padding:20px}
.th{background:linear-gradient(135deg,#1a365d,#0f172a);color:#fff;padding:16px 24px;border-radius:8px;display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
.th h1{margin:0;font-size:1.4rem}.tbdg{background:#6366f1;color:#fff;font-size:.6rem;font-weight:700;padding:2px 8px;border-radius:12px;margin-left:8px}
.tinf{background:#e8f0fe;border:1px solid #4285f4;color:#1a73e8;padding:8px 16px;border-radius:6px;margin-bottom:16px;font-size:.85rem}
.tsr{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:16px}
.tsc{background:#fff;border:1px solid #e0e0e0;border-radius:8px;padding:12px;text-align:center}
.tsc .n{font-size:1.8rem;font-weight:700;display:block}.tsc .l{font-size:.7rem;color:#666;text-transform:capitalize}
.ttb{display:flex;gap:10px;margin-bottom:12px;flex-wrap:wrap}
.ttb input,.ttb select{border:1px solid #ccc;padding:6px 12px;border-radius:6px;font-size:.85rem}.ttb input{flex:1;min-width:180px}
.btn{padding:6px 16px;border:none;border-radius:6px;font-weight:600;font-size:.85rem;cursor:pointer;color:#fff}
.bp{background:#1a73e8}.bg{background:#34a853}.br{background:#ea4335}.bv{background:#9334e6}.bs{background:#e0e0e0;color:#333}.bsm{padding:3px 10px;font-size:.75rem}
table.tt{width:100%;border-collapse:collapse;background:#fff;border:1px solid #e0e0e0;border-radius:8px;overflow:hidden}
.tt th{background:#f8f9fa;color:#666;font-size:.75rem;text-transform:uppercase;padding:8px 12px;text-align:left;border-bottom:2px solid #e0e0e0}
.tt td{padding:8px 12px;border-bottom:1px solid #f0f0f0;vertical-align:top}.tt tr:hover{background:#f8f9fa}
.sb{padding:2px 10px;border-radius:12px;font-size:.7rem;font-weight:600;color:#fff;display:inline-block}
.sd{background:#9e9e9e}.ss{background:#1a73e8}.sa{background:#34a853}.sr{background:#ea4335}.sc{background:#9334e6}
.mbg{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:10000}
.mdl{background:#fff;border-radius:12px;padding:24px;width:90%;max-width:550px;box-shadow:0 8px 32px rgba(0,0,0,.2)}
.mdl h2{margin:0 0 16px;font-size:1.2rem}
.fg{margin-bottom:12px}.fg label{display:block;font-weight:600;font-size:.85rem;margin-bottom:4px;color:#333}
.fg input,.fg textarea,.fg select{width:100%;border:1px solid #ccc;padding:8px;border-radius:6px;font-size:.85rem;font-family:inherit;box-sizing:border-box}
.fg textarea{min-height:60px}.fr{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.fa{display:flex;gap:8px;justify-content:flex-end;margin-top:16px}
.fe{color:#ea4335;font-size:.85rem;margin-bottom:8px}
.em{text-align:center;padding:32px;color:#999}
.cx{float:right;background:none;border:none;font-size:1.2rem;cursor:pointer;color:#666}
</style>

<div class="ta">
<div class="th"><div style="display:flex;align-items:center;gap:8px"><span style="font-size:1.3rem">✈️</span><h1>Travel Requests</h1><span class="tbdg">SDK PURE</span></div><button class="btn bp" onclick="tShow()">+ New Request</button></div>
<div class="tinf"><strong>Approach 1: SDK Pure</strong> — Jelly UI Page, vanilla JS, ServiceNow REST Table API.</div>
<div id="tS" class="tsr"></div>
<div class="ttb"><input id="tQ" placeholder="Search destinations or purpose..." oninput="tR()"/><select id="tF" onchange="tR()"><option value="">All States</option><option value="draft">Draft</option><option value="submitted">Submitted</option><option value="approved">Approved</option><option value="rejected">Rejected</option><option value="completed">Completed</option></select><button class="btn bs" onclick="tL()">↻ Refresh</button></div>
<div id="tG"></div>
</div>

<div id="tMB" class="mbg" style="display:none" onclick="if(event.target===this)tHide()"><div class="mdl"><button class="cx" onclick="tHide()">✕</button><h2>✈️ New Travel Request</h2><div id="tFE"></div><div class="fg"><label>Destination *</label><input id="fD"/></div><div class="fr"><div class="fg"><label>Departure *</label><input id="fP" type="date"/></div><div class="fg"><label>Return *</label><input id="fR" type="date"/></div></div><div class="fg"><label>Purpose *</label><textarea id="fU"></textarea></div><div class="fr"><div class="fg"><label>Cost (USD) *</label><input id="fC" type="number" step="0.01"/></div><div class="fg"><label>Type</label><select id="fT"><option value="domestic">Domestic</option><option value="international">International</option></select></div></div><div class="fa"><button class="btn bs" onclick="tHide()">Cancel</button><button class="btn bp" onclick="tSave()">Create Request</button></div></div></div>
</j:jelly>
