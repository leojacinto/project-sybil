<div id="tS" class="tsr"></div>
<div class="ttb"><input id="tQ" placeholder="Search destinations or purpose..." oninput="tR()"/><select id="tF" onchange="tR()"><option value="">All States</option><option value="draft">Draft</option><option value="submitted">Submitted</option><option value="approved">Approved</option><option value="rejected">Rejected</option><option value="completed">Completed</option></select><button class="btn bs" onclick="location.reload()">↻ Refresh</button></div>
<div id="tG"></div>
</div>

<div id="tMB" class="mbg" style="display:none" onclick="if(event.target===this)this.style.display='none'">
