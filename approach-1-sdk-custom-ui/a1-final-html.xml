<input type="hidden" name="sysparm_ck" value="$[jvar_ck]"/>
<div class="fg"><label>Destination *</label><input name="trv_destination" id="fD" required="required"/></div>
<div class="fr"><div class="fg"><label>Departure *</label><input name="trv_departure" id="fP" type="date" required="required"/></div><div class="fg"><label>Return *</label><input name="trv_return" id="fR" type="date" required="required"/></div></div>
<div class="fg"><label>Purpose *</label><textarea name="trv_purpose" id="fU" required="required"></textarea></div>
<div class="fr"><div class="fg"><label>Cost (USD) *</label><input name="trv_cost" id="fC" type="number" step="0.01" required="required"/></div><div class="fg"><label>Type</label><select name="trv_type"><option value="domestic">Domestic</option><option value="international">International</option></select></div></div>
<div class="fa"><button type="button" class="btn bs" onclick="document.getElementById('tMB').style.display='none'">Cancel</button><button type="submit" class="btn bp">Create Request</button></div>
</form>
</div>
</div>
