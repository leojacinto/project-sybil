.btn{padding:6px 16px;border:none;border-radius:6px;font-weight:600;font-size:.85rem;cursor:pointer;color:#fff}
.bp{background:#1a73e8}.bg{background:#34a853}.br{background:#ea4335}.bv{background:#9334e6}.bs{background:#e0e0e0;color:#333}.bsm{padding:3px 10px;font-size:.75rem}
