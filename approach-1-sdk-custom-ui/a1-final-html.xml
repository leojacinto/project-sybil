</style>

<script>
var TRV_DATA = $[jvar_data];
var TRV_CK = '$[jvar_ck]';
var TRV_MSG = '$[jvar_msg]';
</script>

<div class="ta">
<div class="th"><div style="display:flex;align-items:center;gap:8px"><span style="font-size:1.3rem">✈️</span><h1>Travel Requests</h1><span class="tbdg">SDK PURE</span></div><button class="btn bp" onclick="document.getElementById('tMB').style.display='flex'">+ New Request</button></div>
