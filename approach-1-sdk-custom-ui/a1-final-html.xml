<?xml version="1.0" encoding="utf-8" ?>
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null">

<g:evaluate var="jvar_data" jelly="true" object="true">
var t = 'x_snc_trv_request';
var gr = new GlideRecord(t);
gr.orderByDesc('sys_created_on');
gr.setLimit(100);
gr.query();
var arr = [];
while (gr.next()) {
  arr.push({
    sys_id: gr.getUniqueValue(),
    number: gr.getValue('number') || '',
    destination: gr.getValue('x_snc_virgil_destination') || '',
    departure_date: gr.getValue('x_snc_virgil_departure_date') || '',
    return_date: gr.getValue('x_snc_virgil_return_date') || '',
    purpose: gr.getValue('x_snc_virgil_purpose') || '',
    estimated_cost: gr.getValue('x_snc_virgil_estimated_cost') || '',
    travel_type: gr.getValue('x_snc_virgil_travel_type') || '',
    state: gr.getValue('x_snc_virgil_state') || 'draft'
  });
}
JSON.stringify(arr);
</g:evaluate>

<g:evaluate var="jvar_ck" jelly="true" object="true">
gs.getSession().getSessionToken();
</g:evaluate>

<g:evaluate var="jvar_msg" jelly="true" object="true">
var msg = '';
var action = RP.getParameterValue('trv_action');
if (action == 'create') {
  var gr = new GlideRecord('x_snc_trv_request');
  gr.initialize();
  gr.setValue('x_snc_virgil_destination', RP.getParameterValue('trv_destination'));
  gr.setValue('x_snc_virgil_departure_date', RP.getParameterValue('trv_departure'));
  gr.setValue('x_snc_virgil_return_date', RP.getParameterValue('trv_return'));
  gr.setValue('x_snc_virgil_purpose', RP.getParameterValue('trv_purpose'));
  gr.setValue('x_snc_virgil_estimated_cost', RP.getParameterValue('trv_cost'));
  gr.setValue('x_snc_virgil_travel_type', RP.getParameterValue('trv_type'));
  gr.setValue('x_snc_virgil_state', 'draft');
  gr.insert();
  msg = 'created';
} else if (action == 'update_state') {
  var gr = new GlideRecord('x_snc_trv_request');
  if (gr.get(RP.getParameterValue('trv_id'))) {
    gr.setValue('x_snc_virgil_state', RP.getParameterValue('trv_state'));
    gr.update();
    msg = 'updated';
  }
} else if (action == 'delete') {
  var gr = new GlideRecord('x_snc_trv_request');
  if (gr.get(RP.getParameterValue('trv_id'))) {
    gr.deleteRecord();
    msg = 'deleted';
  }
}
msg;
</g:evaluate>

<style>
